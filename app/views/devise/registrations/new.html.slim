.form-container.col-6.d-flex.justify-content-center#signup-anchor
  = simple_form_for(resource, as: resource_name, html: { class: "signup-form col-12" }, url: registration_path(resource_name)) do |f|
    h1.page-title Sign up
    = f.error_notification

    .form-inputs
      .form-col-2
        = f.input :first_name
        = f.input :last_name
      = f.input :username
      .form-col-2
        = f.input :contact
        = f.input :photo, as: :file
      = f.input :email,
                required: true,
                autofocus: true,
                input_html: { autocomplete: "email" }
      .form-col-2
        = f.input :password,
                  required: true,
                  hint: ("#{@minimum_password_length} characters minimum" if @minimum_password_length),
                  input_html: { autocomplete: "new-password" }
        = f.input :password_confirmation,
                  required: true,
                  input_html: { autocomplete: "new-password" }

    .form-actions
      = f.button :submit, "Sign up", class: "button button-primary"
      = link_to "Log in", new_user_session_path, class: "button-primary-revert"
